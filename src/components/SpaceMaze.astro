<script>
	// @ts-nocheck
	import * as THREE from 'three';
	import { PointerLockControls } from 'three/examples/jsm/controls/PointerLockControls.js';
	import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';
	import { EffectComposer } from 'three/examples/jsm/postprocessing/EffectComposer.js';
	import { RenderPass } from 'three/examples/jsm/postprocessing/RenderPass.js';
	import { UnrealBloomPass } from 'three/examples/jsm/postprocessing/UnrealBloomPass.js';
	import { FilmPass } from 'three/examples/jsm/postprocessing/FilmPass.js';
	import track1Url from '../music/track1.mp3?url';
	import enemyModelUrl from '../models/Fox.glb?url';

	function toAssetUrl(asset) {
		if (!asset) return null;
		if (typeof asset === 'string') return asset;
		if (typeof asset === 'object') {
			if (typeof asset.src === 'string') return asset.src;
			if (typeof asset.default === 'string') return asset.default;
			if (asset.default && typeof asset.default === 'object' && typeof asset.default.src === 'string') {
				return asset.default.src;
			}
		}
		return String(asset);
	}

	function sortAssetUrls(assets) {
		return [...new Set(assets.map(toAssetUrl).filter(Boolean))].toSorted((a, b) =>
			a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' })
		);
	}

	const FLOOR_TEXTURE_URLS = sortAssetUrls(
		Object.values(import.meta.glob('../textures/floors/*.png', { eager: true, import: 'default' }))
	);
	const WALL_TEXTURE_URLS = sortAssetUrls(
		Object.values(import.meta.glob('../textures/walls/**/*.png', { eager: true, import: 'default' }))
	);

	const MAZE_SIZE = 21;
	const LEVEL_COUNT = 5;
	const EXIT_LEVEL = LEVEL_COUNT - 1;
	const CELL_SIZE = 4;
	const WALL_HEIGHT = 3.4;
	const PLAYER_HEIGHT = 1.6;
	const PLAYER_RADIUS = 0.35;
	const MOVE_ACCEL = 120;
	const MOVE_DAMPING = 10;
	const FINISH_DISTANCE = 1.6;
	const HOLES_PER_LEVEL = 2;
	const SPHERES_PER_LEVEL = 2;
	const SECRET_DOOR_COUNT = 2;
	const HOLE_RADIUS = CELL_SIZE * 0.28;
	const SPHERE_RADIUS = CELL_SIZE * 0.23;
	const DROP_DEPTH = 3.5;
	const DROP_SPEED = 12;
	const SECRET_DOOR_TRIGGER_RADIUS = CELL_SIZE * 0.52;
	const FOX_HEIGHT = 0.72;
	const FACE_HEIGHT = 1.04;
	const FOX_SPEED = 2.95;
	const FACE_SPEED = 2.25;
	const ENEMY_ACCEL = 8.4;
	const ENEMY_ROTATE_SPEED = 9.5;
	const ENEMY_REPATH_SECONDS = 0.33;
	const FOX_CATCH_RADIUS = 0.95;
	const FOX_CATCH_COOLDOWN = 1.8;
	const FACE_SHOOT_INTERVAL = 1.25;
	const FACE_SHOOT_RANGE = CELL_SIZE * 6.5;
	const FACE_SHOOT_PATH_MAX = 12;
	const PROJECTILE_RADIUS = 0.16;
	const PROJECTILE_SPEED = 12;
	const PROJECTILE_LIFETIME = 3.2;
	const PLAYER_MAX_HITS = 3;
	const PLAYER_HIT_COOLDOWN = 0.85;
	const CARDINAL_DIRS = [
		[1, 0],
		[-1, 0],
		[0, 1],
		[0, -1]
	];
	const Y_AXIS = new THREE.Vector3(0, 1, 0);
	const HALF_WORLD = (MAZE_SIZE * CELL_SIZE) / 2;

	let scene;
	let camera;
	let renderer;
	let composer;
	let bloomPass;
	let filmPass;
	let controls;
	let clock;
	let levels = [];
	let currentLevel = 0;
	let mazeGroup;
	let exitPosition = new THREE.Vector3();
	let levelTransition = null;
	let music;
	let musicReady = false;
	let textureLoader;
	let gltfLoader;
	let skyMaterial;
	let skyLayer;
	let planetMesh;
	const starLayers = [];
	const regionPulseMaterials = [];
	const transitionSphereMeshes = [];
	const textureCache = new Map();
	const foxEnemy = createEnemyRuntime(FOX_HEIGHT);
	const faceEnemy = createEnemyRuntime(FACE_HEIGHT);
	let playerHits = 0;
	let playerHitCooldown = 0;
	let gameOver = false;
	const projectileDirection = new THREE.Vector3();
	const activeProjectiles = [];
	const projectileGeometry = new THREE.SphereGeometry(PROJECTILE_RADIUS, 12, 12);
	const projectileMaterial = new THREE.MeshStandardMaterial({
		color: 0xff7355,
		emissive: 0x912110,
		emissiveIntensity: 1.1,
		roughness: 0.3,
		metalness: 0.08
	});

	const velocity = new THREE.Vector3();
	const moveState = { forward: false, backward: false, left: false, right: false };
	const forward = new THREE.Vector3();
	const right = new THREE.Vector3();
	const moveIntent = new THREE.Vector3();

	let debugEl;
	let statusEl;
	let healthEl;
	let instructionsEl;
	let startButtonEl;

	function createEnemyRuntime(height) {
		return {
			height,
			actor: null,
			visual: null,
			mixer: null,
			currentLevel: -1,
			catchCooldown: 0,
			shootTimer: FACE_SHOOT_INTERVAL,
			levelStates: [],
			targetWorld: new THREE.Vector3(),
			moveDirection: new THREE.Vector3(),
			lookTarget: new THREE.Vector3(),
			velocity: new THREE.Vector3(),
			lookMatrix: new THREE.Matrix4(),
			targetQuaternion: new THREE.Quaternion()
		};
	}

	function createMaze(size) {
		const grid = Array.from({ length: size }, () => Array(size).fill(1));
		const stack = [[1, 1]];
		const stepDirs = [
			[2, 0],
			[-2, 0],
			[0, 2],
			[0, -2]
		];

		grid[1][1] = 0;

		while (stack.length > 0) {
			const [x, z] = stack[stack.length - 1];
			const choices = [];

			for (const [dx, dz] of stepDirs) {
				const nx = x + dx;
				const nz = z + dz;
				if (nx <= 0 || nz <= 0 || nx >= size - 1 || nz >= size - 1) continue;
				if (grid[nz][nx] !== 1) continue;
				choices.push([nx, nz, x + dx / 2, z + dz / 2]);
			}

			if (choices.length === 0) {
				stack.pop();
				continue;
			}

			const [nx, nz, wx, wz] = choices[Math.floor(Math.random() * choices.length)];
			grid[wz][wx] = 0;
			grid[nz][nx] = 0;
			stack.push([nx, nz]);
		}

		grid[1][1] = 0;
		grid[size - 2][size - 2] = 0;
		return grid;
	}

	function cellToWorld(col, row) {
		return new THREE.Vector3(
			col * CELL_SIZE - HALF_WORLD + CELL_SIZE * 0.5,
			0,
			row * CELL_SIZE - HALF_WORLD + CELL_SIZE * 0.5
		);
	}

	function worldToCell(x, z) {
		return {
			col: Math.floor((x + HALF_WORLD) / CELL_SIZE),
			row: Math.floor((z + HALF_WORLD) / CELL_SIZE)
		};
	}

	function inBounds(col, row) {
		return col >= 0 && row >= 0 && col < MAZE_SIZE && row < MAZE_SIZE;
	}

	function cellKey(col, row) {
		return `${col},${row}`;
	}

	function getCurrentGrid() {
		return levels[currentLevel].grid;
	}

	function isOpenAt(x, z) {
		const { col, row } = worldToCell(x, z);
		if (!inBounds(col, row)) return false;
		const grid = getCurrentGrid();
		return grid[row][col] === 0;
	}

	function canOccupy(x, z) {
		const r = PLAYER_RADIUS;
		return (
			isOpenAt(x, z) &&
			isOpenAt(x + r, z) &&
			isOpenAt(x - r, z) &&
			isOpenAt(x, z + r) &&
			isOpenAt(x, z - r) &&
			isOpenAt(x + r * 0.7, z + r * 0.7) &&
			isOpenAt(x - r * 0.7, z + r * 0.7) &&
			isOpenAt(x + r * 0.7, z - r * 0.7) &&
			isOpenAt(x - r * 0.7, z - r * 0.7)
		);
	}

	function shuffleInPlace(array) {
		for (let i = array.length - 1; i > 0; i--) {
			const j = Math.floor(Math.random() * (i + 1));
			[array[i], array[j]] = [array[j], array[i]];
		}
	}

	function pickLevelTextureUrl(urls, levelIndex, offset = 0) {
		if (urls.length === 0) return null;
		const stride = Math.max(1, Math.floor(urls.length / LEVEL_COUNT));
		return urls[(levelIndex * stride + offset) % urls.length];
	}

	function getTexture(url, repeatX = 1, repeatY = 1) {
		if (!url || !textureLoader) return null;
		let texture = textureCache.get(url);
		if (!texture) {
			texture = textureLoader.load(url);
			texture.colorSpace = THREE.SRGBColorSpace;
			texture.wrapS = THREE.RepeatWrapping;
			texture.wrapT = THREE.RepeatWrapping;
			texture.anisotropy = renderer?.capabilities?.getMaxAnisotropy?.() ?? 1;
			textureCache.set(url, texture);
		}
		texture.repeat.set(repeatX, repeatY);
		return texture;
	}

	function preloadLevelTextures() {
		for (const levelData of levels) {
			getTexture(levelData.floorTextureUrl, 5, 5);
			getTexture(levelData.wallTextureUrl, 1, 1);
		}
	}

	function carveHugeRooms(grid, levelSeed) {
		const roomCount = 2 + (levelSeed % 2);
		for (let i = 0; i < roomCount; i++) {
			const roomWidth = 5 + Math.floor(Math.random() * 4);
			const roomHeight = 5 + Math.floor(Math.random() * 4);
			const startCol = 1 + Math.floor(Math.random() * (MAZE_SIZE - roomWidth - 1));
			const startRow = 1 + Math.floor(Math.random() * (MAZE_SIZE - roomHeight - 1));

			for (let row = startRow; row < startRow + roomHeight; row++) {
				for (let col = startCol; col < startCol + roomWidth; col++) {
					grid[row][col] = 0;
				}
			}

			const centerCol = Math.floor(startCol + roomWidth / 2);
			const centerRow = Math.floor(startRow + roomHeight / 2);
			const carveDirs = [...CARDINAL_DIRS];
			shuffleInPlace(carveDirs);
			for (const [dx, dz] of carveDirs.slice(0, 2)) {
				for (let step = 1; step <= 3; step++) {
					const col = centerCol + dx * step;
					const row = centerRow + dz * step;
					if (!inBounds(col, row)) break;
					if (col <= 0 || row <= 0 || col >= MAZE_SIZE - 1 || row >= MAZE_SIZE - 1) break;
					grid[row][col] = 0;
				}
			}
		}
	}

	function collectTransitionCandidates(upperGrid, lowerGrid) {
		const cells = [];
		for (let row = 1; row < MAZE_SIZE - 1; row++) {
			for (let col = 1; col < MAZE_SIZE - 1; col++) {
				if (upperGrid[row][col] !== 0 || lowerGrid[row][col] !== 0) continue;
				if (col <= 2 && row <= 2) continue;
				cells.push({ col, row });
			}
		}
		return cells;
	}

	function findDeadEnds(grid) {
		const deadEnds = [];
		for (let row = 1; row < MAZE_SIZE - 1; row++) {
			for (let col = 1; col < MAZE_SIZE - 1; col++) {
				if (grid[row][col] !== 0) continue;
				const openNeighbors = [];
				for (const [dx, dz] of CARDINAL_DIRS) {
					const nCol = col + dx;
					const nRow = row + dz;
					if (!inBounds(nCol, nRow)) continue;
					if (grid[nRow][nCol] === 0) {
						openNeighbors.push([dx, dz]);
					}
				}
				if (openNeighbors.length !== 1) continue;
				const [backDx, backDz] = openNeighbors[0];
				deadEnds.push({
					col,
					row,
					doorDx: -backDx,
					doorDz: -backDz
				});
			}
		}
		return deadEnds;
	}

	function buildSecretDoors(grid, count, forbiddenCells) {
		const secretDoors = [];
		const deadEnds = findDeadEnds(grid);
		shuffleInPlace(deadEnds);

		for (const deadEnd of deadEnds) {
			if (secretDoors.length >= count) break;

			const doorCol = deadEnd.col + deadEnd.doorDx;
			const doorRow = deadEnd.row + deadEnd.doorDz;
			const doorKey = cellKey(doorCol, doorRow);
			if (!inBounds(doorCol, doorRow)) continue;
			if (doorCol <= 0 || doorRow <= 0 || doorCol >= MAZE_SIZE - 1 || doorRow >= MAZE_SIZE - 1) continue;
			if (grid[doorRow][doorCol] !== 1) continue;
			if (forbiddenCells.has(doorKey)) continue;

			const beyondCol = deadEnd.col + deadEnd.doorDx * 2;
			const beyondRow = deadEnd.row + deadEnd.doorDz * 2;
			const perpA = { dx: deadEnd.doorDz, dz: -deadEnd.doorDx };
			const perpB = { dx: -deadEnd.doorDz, dz: deadEnd.doorDx };
			const roomCells = [
				{ col: beyondCol, row: beyondRow },
				{ col: beyondCol + perpA.dx, row: beyondRow + perpA.dz },
				{ col: beyondCol + perpB.dx, row: beyondRow + perpB.dz },
				{ col: beyondCol + deadEnd.doorDx, row: beyondRow + deadEnd.doorDz }
			];

			let validRoom = true;
			for (const roomCell of roomCells) {
				if (!inBounds(roomCell.col, roomCell.row)) {
					validRoom = false;
					break;
				}
				if (
					roomCell.col <= 0 ||
					roomCell.row <= 0 ||
					roomCell.col >= MAZE_SIZE - 1 ||
					roomCell.row >= MAZE_SIZE - 1
				) {
					validRoom = false;
					break;
				}
				if (forbiddenCells.has(cellKey(roomCell.col, roomCell.row))) {
					validRoom = false;
					break;
				}
			}
			if (!validRoom) continue;

			for (const roomCell of roomCells) {
				grid[roomCell.row][roomCell.col] = 0;
				forbiddenCells.add(cellKey(roomCell.col, roomCell.row));
			}
			forbiddenCells.add(doorKey);

			secretDoors.push({
				deadEndCol: deadEnd.col,
				deadEndRow: deadEnd.row,
				doorCol,
				doorRow,
				opened: false
			});
		}
		return secretDoors;
	}

	function buildLevels() {
		levels = Array.from({ length: LEVEL_COUNT }, (_, levelIndex) => {
			const grid = createMaze(MAZE_SIZE);
			carveHugeRooms(grid, levelIndex);
			return {
				grid,
				floorTextureUrl: pickLevelTextureUrl(FLOOR_TEXTURE_URLS, levelIndex, 7),
				wallTextureUrl: pickLevelTextureUrl(WALL_TEXTURE_URLS, levelIndex, 13),
				holeMap: new Map(),
				sphereMap: new Map(),
				secretDoors: [],
				wallMeshes: new Map(),
				reservedTransitions: new Set(),
				foxSpawn: { col: 1, row: 1 },
				faceSpawn: { col: 1, row: 1 }
			};
		});

		levels[0].grid[1][1] = 0;
		levels[EXIT_LEVEL].grid[MAZE_SIZE - 2][MAZE_SIZE - 2] = 0;

		for (let level = 0; level < LEVEL_COUNT - 1; level++) {
			const upper = levels[level];
			const lower = levels[level + 1];
			const candidates = collectTransitionCandidates(upper.grid, lower.grid).filter(({ col, row }) => {
				const key = cellKey(col, row);
				if (upper.reservedTransitions.has(key) || lower.reservedTransitions.has(key)) return false;
				if (level === EXIT_LEVEL - 1 && col >= MAZE_SIZE - 3 && row >= MAZE_SIZE - 3) return false;
				return true;
			});
			shuffleInPlace(candidates);

			let holesPlaced = 0;
			let spheresPlaced = 0;
			for (const candidate of candidates) {
				if (holesPlaced >= HOLES_PER_LEVEL && spheresPlaced >= SPHERES_PER_LEVEL) break;
				const key = cellKey(candidate.col, candidate.row);

				if (holesPlaced < HOLES_PER_LEVEL && !upper.holeMap.has(key) && !upper.sphereMap.has(key)) {
					upper.holeMap.set(key, {
						col: candidate.col,
						row: candidate.row,
						targetLevel: level + 1
					});
					upper.reservedTransitions.add(key);
					lower.reservedTransitions.add(key);
					holesPlaced++;
					continue;
				}

				if (spheresPlaced < SPHERES_PER_LEVEL && !lower.holeMap.has(key) && !lower.sphereMap.has(key)) {
					lower.sphereMap.set(key, {
						col: candidate.col,
						row: candidate.row,
						targetLevel: level
					});
					upper.reservedTransitions.add(key);
					lower.reservedTransitions.add(key);
					spheresPlaced++;
				}
			}
		}

		for (let level = 0; level < LEVEL_COUNT; level++) {
			const forbiddenCells = new Set([...levels[level].holeMap.keys(), ...levels[level].sphereMap.keys()]);
			if (level === 0) forbiddenCells.add(cellKey(1, 1));
			if (level === EXIT_LEVEL) forbiddenCells.add(cellKey(MAZE_SIZE - 2, MAZE_SIZE - 2));
			levels[level].secretDoors = buildSecretDoors(levels[level].grid, SECRET_DOOR_COUNT, forbiddenCells);
			delete levels[level].reservedTransitions;
		}

		foxEnemy.levelStates.length = 0;
		faceEnemy.levelStates.length = 0;
		for (let level = 0; level < LEVEL_COUNT; level++) {
			const spawnBlocks = new Set([...levels[level].holeMap.keys(), ...levels[level].sphereMap.keys()]);
			spawnBlocks.add(cellKey(1, 1));
			if (level === EXIT_LEVEL) spawnBlocks.add(cellKey(MAZE_SIZE - 2, MAZE_SIZE - 2));

			const foxSpawn = pickEnemySpawnCell(level, spawnBlocks);
			spawnBlocks.add(cellKey(foxSpawn.col, foxSpawn.row));
			const faceSpawn = pickEnemySpawnCell(level, spawnBlocks);
			levels[level].foxSpawn = foxSpawn;
			levels[level].faceSpawn = faceSpawn;

			foxEnemy.levelStates.push({
				col: foxSpawn.col,
				row: foxSpawn.row,
				path: [],
				pathIndex: 0,
				targetCellKey: '',
				repathTimer: 0
			});
			faceEnemy.levelStates.push({
				col: faceSpawn.col,
				row: faceSpawn.row,
				path: [],
				pathIndex: 0,
				targetCellKey: '',
				repathTimer: 0
			});
		}

		currentLevel = 0;
		exitPosition = cellToWorld(MAZE_SIZE - 2, MAZE_SIZE - 2);
	}

	function pickEnemySpawnCell(levelIndex, extraForbiddenCells = null) {
		const grid = levels[levelIndex].grid;
		const forbidden = new Set([...levels[levelIndex].holeMap.keys(), ...levels[levelIndex].sphereMap.keys()]);
		if (extraForbiddenCells) {
			for (const key of extraForbiddenCells) forbidden.add(key);
		}
		forbidden.add(cellKey(1, 1));
		if (levelIndex === EXIT_LEVEL) forbidden.add(cellKey(MAZE_SIZE - 2, MAZE_SIZE - 2));

		let best = null;
		let bestScore = -Infinity;

		for (let row = 1; row < MAZE_SIZE - 1; row++) {
			for (let col = 1; col < MAZE_SIZE - 1; col++) {
				if (grid[row][col] !== 0) continue;
				const key = cellKey(col, row);
				if (forbidden.has(key)) continue;

				const distanceFromStart = Math.hypot(col - 1, row - 1);
				if (distanceFromStart < MAZE_SIZE * 0.42) continue;
				const distanceFromExit =
					levelIndex === EXIT_LEVEL ? Math.hypot(col - (MAZE_SIZE - 2), row - (MAZE_SIZE - 2)) : MAZE_SIZE;
				const score = distanceFromStart + distanceFromExit * 0.2 + Math.random() * 0.25;
				if (score > bestScore) {
					bestScore = score;
					best = { col, row };
				}
			}
		}

		if (best) return best;
		for (let row = 1; row < MAZE_SIZE - 1; row++) {
			for (let col = 1; col < MAZE_SIZE - 1; col++) {
				if (grid[row][col] !== 0) continue;
				if (forbidden.has(cellKey(col, row))) continue;
				return { col, row };
			}
		}
		return { col: 1, row: 1 };
	}

	function keyToCell(key) {
		const [col, row] = key.split(',').map((v) => Number.parseInt(v, 10));
		return { col, row };
	}

	function findCellPath(grid, startCol, startRow, targetCol, targetRow) {
		if (!inBounds(startCol, startRow) || !inBounds(targetCol, targetRow)) return [];
		if (grid[startRow][startCol] !== 0 || grid[targetRow][targetCol] !== 0) return [];
		if (startCol === targetCol && startRow === targetRow) return [];

		const startKey = cellKey(startCol, startRow);
		const targetKey = cellKey(targetCol, targetRow);
		const queue = [{ col: startCol, row: startRow }];
		const visited = new Set([startKey]);
		const previous = new Map();
		let found = false;
		let cursor = 0;

		while (cursor < queue.length) {
			const current = queue[cursor++];
			for (const [dx, dz] of CARDINAL_DIRS) {
				const nextCol = current.col + dx;
				const nextRow = current.row + dz;
				if (!inBounds(nextCol, nextRow)) continue;
				if (grid[nextRow][nextCol] !== 0) continue;

				const nextKey = cellKey(nextCol, nextRow);
				if (visited.has(nextKey)) continue;
				visited.add(nextKey);
				previous.set(nextKey, cellKey(current.col, current.row));

				if (nextKey === targetKey) {
					found = true;
					cursor = queue.length;
					break;
				}
				queue.push({ col: nextCol, row: nextRow });
			}
		}

		if (!found) return [];
		const path = [];
		let walkKey = targetKey;
		while (walkKey !== startKey) {
			path.push(keyToCell(walkKey));
			walkKey = previous.get(walkKey);
			if (!walkKey) return [];
		}
		path.reverse();
		return path;
	}

	function getRegionIndex(col, row) {
		const half = MAZE_SIZE / 2;
		const xRegion = col < half ? 0 : 1;
		const zRegion = row < half ? 0 : 2;
		return xRegion + zRegion;
	}

	function buildMazeScene(levelIndex) {
		if (mazeGroup) scene.remove(mazeGroup);
		regionPulseMaterials.length = 0;
		transitionSphereMeshes.length = 0;

		mazeGroup = new THREE.Group();
		const levelData = levels[levelIndex];
		const isLowerLevel = levelIndex === EXIT_LEVEL;
		levelData.wallMeshes = new Map();
		const worldSize = MAZE_SIZE * CELL_SIZE;
		const sectionSize = worldSize / 2;
		const sectionOffset = worldSize * 0.25;
		const floorTexture = getTexture(levelData.floorTextureUrl, sectionSize / CELL_SIZE, sectionSize / CELL_SIZE);
		const wallTexture = getTexture(levelData.wallTextureUrl, 1, 1);
		const sectionConfigs = isLowerLevel
			? [
					{ floor: 0x3a415a, wall: 0x8f9ebc, edge: 0x9fc0ff },
					{ floor: 0x354857, wall: 0x84b4c2, edge: 0x8ee2ff },
					{ floor: 0x463d5d, wall: 0xa495d3, edge: 0xc8adff },
					{ floor: 0x3b4d4e, wall: 0x8fc2b6, edge: 0x91f2d6 }
				]
			: [
					{ floor: 0x37426b, wall: 0x7e96cf, edge: 0x95b7ff },
					{ floor: 0x304b63, wall: 0x72b3d4, edge: 0x79e1ff },
					{ floor: 0x4a3b68, wall: 0x9d86cc, edge: 0xc39cff },
					{ floor: 0x2f4d56, wall: 0x71b8ba, edge: 0x75e6d5 }
				];

		const floorGeometry = new THREE.PlaneGeometry(sectionSize, sectionSize);
		for (let rowSection = 0; rowSection < 2; rowSection++) {
			for (let colSection = 0; colSection < 2; colSection++) {
				const sectionIndex = colSection + rowSection * 2;
				const config = sectionConfigs[sectionIndex];
				const floorMaterial = new THREE.MeshStandardMaterial({
					map: floorTexture,
					color: floorTexture ? 0xffffff : config.floor,
					emissive: floorTexture ? 0x181f2d : config.floor,
					emissiveIntensity: floorTexture ? 0.04 : 0.075,
					roughness: floorTexture ? 0.95 : 0.92,
					metalness: 0.03
				});
				floorMaterial.userData.baseEmissive = floorTexture ? 0.04 : 0.075;
				floorMaterial.userData.pulseAmp = 0.03;
				const floor = new THREE.Mesh(floorGeometry, floorMaterial);
				floor.rotation.x = -Math.PI / 2;
				floor.position.set(
					(colSection === 0 ? -sectionOffset : sectionOffset),
					0,
					rowSection === 0 ? -sectionOffset : sectionOffset
				);
				mazeGroup.add(floor);
				regionPulseMaterials.push(floorMaterial);

				const linePoints = [
					new THREE.Vector3(-sectionSize * 0.48, 0.08, -sectionSize * 0.48),
					new THREE.Vector3(sectionSize * 0.48, 0.08, -sectionSize * 0.48),
					new THREE.Vector3(sectionSize * 0.48, 0.08, sectionSize * 0.48),
					new THREE.Vector3(-sectionSize * 0.48, 0.08, sectionSize * 0.48)
				];
				const sectionOutline = new THREE.LineLoop(
					new THREE.BufferGeometry().setFromPoints(linePoints),
					new THREE.LineBasicMaterial({
						color: config.edge,
						transparent: true,
						opacity: 0.65
					})
				);
				sectionOutline.position.set(floor.position.x, 0, floor.position.z);
				mazeGroup.add(sectionOutline);
			}
		}

		const wallGeometry = new THREE.BoxGeometry(CELL_SIZE, WALL_HEIGHT, CELL_SIZE);
		const wallMaterials = sectionConfigs.map((config) => {
			const material = new THREE.MeshStandardMaterial({
				map: wallTexture,
				color: wallTexture ? 0xffffff : config.wall,
				emissive: config.edge,
				emissiveIntensity: wallTexture ? 0.08 : 0.12,
				roughness: wallTexture ? 0.87 : 0.72,
				metalness: wallTexture ? 0.04 : 0.16
			});
			material.userData.baseEmissive = wallTexture ? 0.08 : 0.12;
			material.userData.pulseAmp = wallTexture ? 0.04 : 0.07;
			regionPulseMaterials.push(material);
			return material;
		});

		for (let row = 0; row < MAZE_SIZE; row++) {
			for (let col = 0; col < MAZE_SIZE; col++) {
				if (levelData.grid[row][col] !== 1) continue;
				const wall = new THREE.Mesh(wallGeometry, wallMaterials[getRegionIndex(col, row)]);
				const p = cellToWorld(col, row);
				wall.position.set(p.x, WALL_HEIGHT * 0.5, p.z);
				mazeGroup.add(wall);
				levelData.wallMeshes.set(cellKey(col, row), wall);
			}
		}

		if (levelData.holeMap.size > 0) {
			const dropMaterial = new THREE.MeshStandardMaterial({
				color: 0xff4a3a,
				emissive: 0x7a1710,
				emissiveIntensity: 1.05,
				roughness: 0.34,
				metalness: 0.14
			});
			const auraMaterial = new THREE.MeshBasicMaterial({
				color: 0xff8a80,
				transparent: true,
				opacity: 0.26,
				side: THREE.DoubleSide
			});
			const sphereGeometry = new THREE.SphereGeometry(HOLE_RADIUS * 0.82, 22, 22);
			const auraGeometry = new THREE.RingGeometry(HOLE_RADIUS * 1.05, HOLE_RADIUS * 1.6, 30);

			for (const hole of levelData.holeMap.values()) {
				const p = cellToWorld(hole.col, hole.row);
				const orb = new THREE.Mesh(sphereGeometry, dropMaterial);
				const baseY = 0.72;
				orb.position.set(p.x, baseY, p.z);
				mazeGroup.add(orb);

				const aura = new THREE.Mesh(auraGeometry, auraMaterial);
				aura.rotation.x = -Math.PI / 2;
				aura.position.set(p.x, 0.1, p.z);
				mazeGroup.add(aura);

				transitionSphereMeshes.push({
					orb,
					aura,
					baseY,
					phase: Math.random() * Math.PI * 2
				});
			}
		}

		if (levelData.sphereMap.size > 0) {
			const liftMaterial = new THREE.MeshStandardMaterial({
				color: 0x55ff8f,
				emissive: 0x1f8b43,
				emissiveIntensity: 1.1,
				roughness: 0.35,
				metalness: 0.12
			});
			const auraMaterial = new THREE.MeshBasicMaterial({
				color: 0xb8ffd1,
				transparent: true,
				opacity: 0.3,
				side: THREE.DoubleSide
			});
			const sphereGeometry = new THREE.SphereGeometry(SPHERE_RADIUS, 20, 20);
			const auraGeometry = new THREE.RingGeometry(SPHERE_RADIUS * 1.2, SPHERE_RADIUS * 1.8, 28);

			for (const sphere of levelData.sphereMap.values()) {
				const p = cellToWorld(sphere.col, sphere.row);
				const orb = new THREE.Mesh(sphereGeometry, liftMaterial);
				const baseY = 0.75;
				orb.position.set(p.x, baseY, p.z);
				mazeGroup.add(orb);

				const aura = new THREE.Mesh(auraGeometry, auraMaterial);
				aura.rotation.x = -Math.PI / 2;
				aura.position.set(p.x, 0.1, p.z);
				mazeGroup.add(aura);

				transitionSphereMeshes.push({
					orb,
					aura,
					baseY,
					phase: Math.random() * Math.PI * 2
				});
			}
		}

		if (isLowerLevel) {
			const exitMarker = new THREE.Mesh(
				new THREE.CylinderGeometry(0.42, 0.72, 1.28, 16),
				new THREE.MeshStandardMaterial({
					color: 0x76ffac,
					emissive: 0x2ea96e,
					emissiveIntensity: 1.35
				})
			);
			exitMarker.position.set(exitPosition.x, 0.64, exitPosition.z);
			mazeGroup.add(exitMarker);
		}

		scene.add(mazeGroup);
	}

	function createStarField(count, minRadius, maxRadius, size, color, opacity) {
		const starPositions = new Float32Array(count * 3);
		for (let i = 0; i < count; i++) {
			const angle = Math.random() * Math.PI * 2;
			const radius = minRadius + Math.random() * (maxRadius - minRadius);
			const height = 18 + Math.random() * 130;
			starPositions[i * 3] = Math.cos(angle) * radius;
			starPositions[i * 3 + 1] = height;
			starPositions[i * 3 + 2] = Math.sin(angle) * radius;
		}

		const starGeometry = new THREE.BufferGeometry();
		starGeometry.setAttribute('position', new THREE.BufferAttribute(starPositions, 3));
		const stars = new THREE.Points(
			starGeometry,
			new THREE.PointsMaterial({
				color,
				size,
				opacity,
				transparent: true,
				sizeAttenuation: true
			})
		);
		stars.userData.baseY = 0;
		return stars;
	}

	function addSkyBackdrop() {
		skyMaterial = new THREE.ShaderMaterial({
			side: THREE.BackSide,
			depthWrite: false,
			uniforms: {
				topColor: { value: new THREE.Color(0x16388f) },
				horizonColor: { value: new THREE.Color(0x2a569f) },
				bottomColor: { value: new THREE.Color(0x0f1736) },
				time: { value: 0 }
			},
			vertexShader: `
				varying vec3 vWorldPosition;
				void main() {
					vec4 worldPosition = modelMatrix * vec4(position, 1.0);
					vWorldPosition = worldPosition.xyz;
					gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
				}
			`,
			fragmentShader: `
				uniform vec3 topColor;
				uniform vec3 horizonColor;
				uniform vec3 bottomColor;
				uniform float time;
				varying vec3 vWorldPosition;
				void main() {
					vec3 dir = normalize(vWorldPosition);
					float h = dir.y;
					float topMix = smoothstep(0.0, 0.92, h);
					float bottomMix = smoothstep(-1.0, -0.2, h);
					float wave = sin((dir.x + time * 0.04) * 12.0) * sin((dir.z - time * 0.03) * 11.0);
					float cloudBand = smoothstep(-0.25, 0.55, h) * 0.06 * wave;
					vec3 color = mix(horizonColor, topColor, topMix);
					color += vec3(0.20, 0.14, 0.34) * cloudBand;
					color = mix(color, bottomColor, bottomMix);
					gl_FragColor = vec4(color, 1.0);
				}
			`
		});

		skyLayer = new THREE.Mesh(
			new THREE.SphereGeometry(260, 48, 32),
			skyMaterial
		);
		skyLayer.position.y = -24;
		scene.add(skyLayer);

		planetMesh = new THREE.Mesh(
			new THREE.SphereGeometry(7.2, 30, 30),
			new THREE.MeshStandardMaterial({
				color: 0x97b9ff,
				emissive: 0x2f5baf,
				emissiveIntensity: 0.62,
				roughness: 0.68,
				metalness: 0.05
			})
		);
		planetMesh.position.set(-56, 62, -45);
		scene.add(planetMesh);

		starLayers.length = 0;
		const farStars = createStarField(840, 42, 200, 1.15, 0xffffff, 0.9);
		const nearStars = createStarField(520, 26, 166, 2.2, 0x9dd0ff, 0.48);
		starLayers.push(farStars, nearStars);
		for (const stars of starLayers) {
			stars.position.y = -2;
			scene.add(stars);
		}
	}

	function onKeyDown(event) {
		switch (event.code) {
			case 'ArrowUp':
			case 'KeyW':
				moveState.forward = true;
				break;
			case 'ArrowDown':
			case 'KeyS':
				moveState.backward = true;
				break;
			case 'ArrowLeft':
			case 'KeyA':
				moveState.left = true;
				break;
			case 'ArrowRight':
			case 'KeyD':
				moveState.right = true;
				break;
			case 'Space':
				event.preventDefault();
				tryOpenSecretDoor();
				break;
		}
	}

	function onKeyUp(event) {
		switch (event.code) {
			case 'ArrowUp':
			case 'KeyW':
				moveState.forward = false;
				break;
			case 'ArrowDown':
			case 'KeyS':
				moveState.backward = false;
				break;
			case 'ArrowLeft':
			case 'KeyA':
				moveState.left = false;
				break;
			case 'ArrowRight':
			case 'KeyD':
				moveState.right = false;
				break;
		}
	}

	function tryOpenSecretDoor() {
		if (!controls?.isLocked || levelTransition) return;
		const levelData = levels[currentLevel];
		if (!levelData?.secretDoors?.length) return;

		const playerCell = worldToCell(camera.position.x, camera.position.z);
		for (const door of levelData.secretDoors) {
			if (door.opened) continue;
			if (playerCell.col !== door.deadEndCol || playerCell.row !== door.deadEndRow) continue;

			const deadEndCenter = cellToWorld(door.deadEndCol, door.deadEndRow);
			const dx = camera.position.x - deadEndCenter.x;
			const dz = camera.position.z - deadEndCenter.z;
			if (dx * dx + dz * dz > SECRET_DOOR_TRIGGER_RADIUS * SECRET_DOOR_TRIGGER_RADIUS) continue;

			door.opened = true;
			levelData.grid[door.doorRow][door.doorCol] = 0;
			const doorKey = cellKey(door.doorCol, door.doorRow);
			const wall = levelData.wallMeshes.get(doorKey);
			if (wall) {
				mazeGroup.remove(wall);
				levelData.wallMeshes.delete(doorKey);
			}
			statusEl.textContent = 'A hidden door opens.';
			return;
		}
	}

	function beginLevelTransition(targetLevel, direction) {
		if (levelTransition) return;
		velocity.set(0, 0, 0);
		levelTransition = {
			targetLevel,
			direction,
			switchedLevel: false
		};
	}

	function updateLevelTransition(delta) {
		if (!levelTransition) return;

		const goingDown = levelTransition.direction === 'down';
		const moveOut = goingDown ? -1 : 1;
		const outTargetY = goingDown ? -DROP_DEPTH : PLAYER_HEIGHT + DROP_DEPTH;

		if (!levelTransition.switchedLevel) {
			camera.position.y += moveOut * DROP_SPEED * delta;
			if ((goingDown && camera.position.y <= outTargetY) || (!goingDown && camera.position.y >= outTargetY)) {
				currentLevel = levelTransition.targetLevel;
				buildMazeScene(currentLevel);
				clearProjectiles();
				syncEnemiesForCurrentLevel(true);
				camera.position.y = outTargetY;
				levelTransition.switchedLevel = true;
			}
			return;
		}

		const moveIn = goingDown ? 1 : -1;
		camera.position.y += moveIn * DROP_SPEED * delta;
		if ((goingDown && camera.position.y >= PLAYER_HEIGHT) || (!goingDown && camera.position.y <= PLAYER_HEIGHT)) {
			camera.position.y = PLAYER_HEIGHT;
			levelTransition = null;
		}
	}

	function maybeDropThroughDropSphere() {
		if (levelTransition) return;

		const { col, row } = worldToCell(camera.position.x, camera.position.z);
		const hole = levels[currentLevel].holeMap.get(cellKey(col, row));
		if (!hole) return;

		const center = cellToWorld(hole.col, hole.row);
		const dx = camera.position.x - center.x;
		const dz = camera.position.z - center.z;
		if (dx * dx + dz * dz <= HOLE_RADIUS * HOLE_RADIUS) {
			beginLevelTransition(hole.targetLevel, 'down');
		}
	}

	function maybeRiseThroughSphere() {
		if (levelTransition) return;

		const { col, row } = worldToCell(camera.position.x, camera.position.z);
		const sphere = levels[currentLevel].sphereMap.get(cellKey(col, row));
		if (!sphere) return;

		const center = cellToWorld(sphere.col, sphere.row);
		const dx = camera.position.x - center.x;
		const dz = camera.position.z - center.z;
		if (dx * dx + dz * dz <= SPHERE_RADIUS * SPHERE_RADIUS) {
			beginLevelTransition(sphere.targetLevel, 'up');
		}
	}

	function updateMovement(delta) {
		velocity.x -= velocity.x * MOVE_DAMPING * delta;
		velocity.z -= velocity.z * MOVE_DAMPING * delta;

		camera.getWorldDirection(forward);
		forward.y = 0;
		forward.normalize();
		right.crossVectors(forward, Y_AXIS).normalize();

		moveIntent.set(0, 0, 0);
		moveIntent.addScaledVector(forward, Number(moveState.forward) - Number(moveState.backward));
		moveIntent.addScaledVector(right, Number(moveState.right) - Number(moveState.left));
		if (moveIntent.lengthSq() > 0) moveIntent.normalize();

		velocity.x += moveIntent.x * MOVE_ACCEL * delta;
		velocity.z += moveIntent.z * MOVE_ACCEL * delta;

		const nextX = camera.position.x + velocity.x * delta;
		const nextZ = camera.position.z + velocity.z * delta;

		if (canOccupy(nextX, camera.position.z)) {
			camera.position.x = nextX;
		} else {
			velocity.x = 0;
		}

		if (canOccupy(camera.position.x, nextZ)) {
			camera.position.z = nextZ;
		} else {
			velocity.z = 0;
		}

		camera.position.y = PLAYER_HEIGHT;
	}

	function createFallbackFoxVisual() {
		const group = new THREE.Group();
		const body = new THREE.Mesh(
			new THREE.CapsuleGeometry(0.3, 0.9, 8, 14),
			new THREE.MeshStandardMaterial({
				color: 0xff9a64,
				emissive: 0x55230f,
				emissiveIntensity: 0.35,
				roughness: 0.55,
				metalness: 0.1
			})
		);
		const eyeMaterial = new THREE.MeshBasicMaterial({ color: 0xfff1dc });
		const leftEye = new THREE.Mesh(new THREE.SphereGeometry(0.06, 10, 10), eyeMaterial);
		const rightEye = leftEye.clone();
		leftEye.position.set(-0.12, 0.64, 0.23);
		rightEye.position.set(0.12, 0.64, 0.23);
		group.add(body, leftEye, rightEye);
		return group;
	}

	function createFaceEnemyVisual() {
		const group = new THREE.Group();
		const face = new THREE.Mesh(
			new THREE.SphereGeometry(0.72, 26, 24),
			new THREE.MeshStandardMaterial({
				color: 0x8fd9ff,
				emissive: 0x1b4f69,
				emissiveIntensity: 0.52,
				roughness: 0.4,
				metalness: 0.2
			})
		);
		const eyeGeometry = new THREE.SphereGeometry(0.1, 10, 10);
		const eyeMaterial = new THREE.MeshBasicMaterial({ color: 0x072a3a });
		const leftEye = new THREE.Mesh(eyeGeometry, eyeMaterial);
		const rightEye = new THREE.Mesh(eyeGeometry, eyeMaterial);
		leftEye.position.set(-0.21, 0.14, 0.62);
		rightEye.position.set(0.21, 0.14, 0.62);
		const mouth = new THREE.Mesh(
			new THREE.TorusGeometry(0.22, 0.04, 8, 18, Math.PI),
			new THREE.MeshBasicMaterial({ color: 0x0f2a37 })
		);
		mouth.position.set(0, -0.22, 0.62);
		mouth.rotation.z = Math.PI;
		group.add(face, leftEye, rightEye, mouth);
		return group;
	}

	function initEnemies() {
		foxEnemy.actor = new THREE.Group();
		foxEnemy.actor.visible = false;
		foxEnemy.visual = createFallbackFoxVisual();
		foxEnemy.actor.add(foxEnemy.visual);
		scene.add(foxEnemy.actor);

		faceEnemy.actor = new THREE.Group();
		faceEnemy.actor.visible = false;
		faceEnemy.visual = createFaceEnemyVisual();
		faceEnemy.actor.add(faceEnemy.visual);
		scene.add(faceEnemy.actor);
	}

	function clearProjectiles() {
		for (const projectile of activeProjectiles) {
			scene.remove(projectile.mesh);
		}
		activeProjectiles.length = 0;
	}

	function endGame() {
		gameOver = true;
		clearProjectiles();
		statusEl.textContent = 'Game over. The fox and face got you. Press ENTER MAZE to restart.';
		startButtonEl.textContent = 'ENTER MAZE';
		if (controls?.isLocked) controls.unlock();
		setMusicPlaying(false);
	}

	function registerPlayerHit(reason) {
		if (gameOver || playerHitCooldown > 0) return false;
		playerHitCooldown = PLAYER_HIT_COOLDOWN;
		playerHits++;
		if (playerHits >= PLAYER_MAX_HITS) {
			endGame();
			return true;
		}

		if (reason === 'fox-touch') {
			resetPlayerToLevelStart();
			resetEnemiesForLevel(currentLevel);
			clearProjectiles();
		}
		statusEl.textContent = `You were hit (${playerHits}/${PLAYER_MAX_HITS}).`;
		return true;
	}

	function spawnFaceProjectile() {
		if (!faceEnemy.actor || gameOver) return;
		projectileDirection.set(camera.position.x - faceEnemy.actor.position.x, 0, camera.position.z - faceEnemy.actor.position.z);
		if (projectileDirection.lengthSq() < 0.0001) return;
		projectileDirection.normalize();

		const mesh = new THREE.Mesh(projectileGeometry, projectileMaterial);
		mesh.position.set(
			faceEnemy.actor.position.x + projectileDirection.x * 0.7,
			faceEnemy.height + 0.25,
			faceEnemy.actor.position.z + projectileDirection.z * 0.7
		);
		scene.add(mesh);
		activeProjectiles.push({
			level: currentLevel,
			ttl: PROJECTILE_LIFETIME,
			mesh,
			velocity: new THREE.Vector3(
				projectileDirection.x * PROJECTILE_SPEED,
				0,
				projectileDirection.z * PROJECTILE_SPEED
			)
		});
	}

	function removeProjectile(index) {
		const projectile = activeProjectiles[index];
		if (!projectile) return;
		scene.remove(projectile.mesh);
		activeProjectiles.splice(index, 1);
	}

	function updateProjectiles(delta) {
		for (let i = activeProjectiles.length - 1; i >= 0; i--) {
			const projectile = activeProjectiles[i];
			if (projectile.level !== currentLevel) {
				removeProjectile(i);
				continue;
			}

			projectile.ttl -= delta;
			if (projectile.ttl <= 0) {
				removeProjectile(i);
				continue;
			}

			projectile.mesh.position.addScaledVector(projectile.velocity, delta);

			if (!isOpenAt(projectile.mesh.position.x, projectile.mesh.position.z)) {
				removeProjectile(i);
				continue;
			}

			const dx = camera.position.x - projectile.mesh.position.x;
			const dz = camera.position.z - projectile.mesh.position.z;
			const hitRadius = PROJECTILE_RADIUS + PLAYER_RADIUS * 0.75;
			if (dx * dx + dz * dz > hitRadius * hitRadius) continue;
			removeProjectile(i);
			registerPlayerHit('projectile');
		}
	}

	function loadFoxModel() {
		if (!gltfLoader) return;
		gltfLoader.load(
			enemyModelUrl,
			(gltf) => {
				if (!foxEnemy.actor) return;
				if (foxEnemy.visual) foxEnemy.actor.remove(foxEnemy.visual);
				foxEnemy.mixer = null;

				const model = gltf.scene;
				model.scale.setScalar(0.022);
				model.position.y = -0.68;
				model.traverse((child) => {
					if (!child.isMesh) return;
					child.castShadow = false;
					child.receiveShadow = false;
				});
				foxEnemy.visual = model;
				foxEnemy.actor.add(foxEnemy.visual);

				if (gltf.animations.length > 0) {
					foxEnemy.mixer = new THREE.AnimationMixer(model);
					const clip =
						gltf.animations.find((animation) => /run|walk/i.test(animation.name)) ?? gltf.animations[0];
					foxEnemy.mixer.clipAction(clip).play();
				}
			},
			undefined,
			() => {
				// Keep fallback visual when model load fails.
			}
		);
	}

	function syncEnemyForCurrentLevel(enemy, spawnKey, forceResetPath = false) {
		if (!enemy.actor || !enemy.levelStates[currentLevel]) return;
		const levelState = enemy.levelStates[currentLevel];
		if (forceResetPath) {
			levelState.path = [];
			levelState.pathIndex = 0;
			levelState.targetCellKey = '';
			levelState.repathTimer = 0;
		}
		const levelSpawn = levels[currentLevel]?.[spawnKey];
		if (forceResetPath && levelSpawn) {
			levelState.col = levelSpawn.col;
			levelState.row = levelSpawn.row;
		}
		const spawnWorld = cellToWorld(levelState.col, levelState.row);
		enemy.actor.position.set(spawnWorld.x, enemy.height, spawnWorld.z);
		enemy.actor.visible = true;
		enemy.velocity.set(0, 0, 0);
		enemy.currentLevel = currentLevel;
	}

	function syncEnemiesForCurrentLevel(forceResetPath = false) {
		syncEnemyForCurrentLevel(foxEnemy, 'foxSpawn', forceResetPath);
		syncEnemyForCurrentLevel(faceEnemy, 'faceSpawn', forceResetPath);
		faceEnemy.shootTimer = FACE_SHOOT_INTERVAL * (0.65 + Math.random() * 0.5);
	}

	function resetPlayerToLevelStart() {
		const start = cellToWorld(1, 1);
		camera.position.set(start.x, PLAYER_HEIGHT, start.z);
		velocity.set(0, 0, 0);
	}

	function resetEnemyForLevel(enemy, levelIndex, spawnKey) {
		const levelState = enemy.levelStates[levelIndex];
		if (!levelState) return;
		const spawn = levels[levelIndex][spawnKey] ?? { col: MAZE_SIZE - 2, row: 1 };
		levelState.col = spawn.col;
		levelState.row = spawn.row;
		levelState.path = [];
		levelState.pathIndex = 0;
		levelState.targetCellKey = '';
		levelState.repathTimer = 0;
		if (enemy.actor && enemy.currentLevel === levelIndex) {
			const p = cellToWorld(spawn.col, spawn.row);
			enemy.actor.position.set(p.x, enemy.height, p.z);
			enemy.velocity.set(0, 0, 0);
		}
	}

	function resetEnemiesForLevel(levelIndex) {
		resetEnemyForLevel(foxEnemy, levelIndex, 'foxSpawn');
		resetEnemyForLevel(faceEnemy, levelIndex, 'faceSpawn');
	}

	function resetRun() {
		gameOver = false;
		playerHits = 0;
		playerHitCooldown = 0;
		foxEnemy.catchCooldown = 0;
		faceEnemy.shootTimer = FACE_SHOOT_INTERVAL;
		clearProjectiles();
		buildLevels();
		preloadLevelTextures();
		buildMazeScene(currentLevel);
		syncEnemiesForCurrentLevel(true);
		resetPlayerToLevelStart();
	}

	function updateEnemyChase(enemy, levelState, grid, targetCell, delta, speed) {
		levelState.repathTimer -= delta;
		const targetKey = cellKey(targetCell.col, targetCell.row);
		if (
			levelState.repathTimer <= 0 ||
			levelState.targetCellKey !== targetKey ||
			levelState.pathIndex >= levelState.path.length
		) {
			levelState.path = findCellPath(grid, levelState.col, levelState.row, targetCell.col, targetCell.row);
			levelState.pathIndex = 0;
			levelState.targetCellKey = targetKey;
			levelState.repathTimer = ENEMY_REPATH_SECONDS;
		}

		if (levelState.pathIndex < levelState.path.length) {
			const waypoint = levelState.path[levelState.pathIndex];
			const waypointWorld = cellToWorld(waypoint.col, waypoint.row);
			enemy.targetWorld.set(waypointWorld.x, enemy.height, waypointWorld.z);
			enemy.moveDirection.subVectors(enemy.targetWorld, enemy.actor.position);
			enemy.moveDirection.y = 0;
			const distance = enemy.moveDirection.length();

			if (distance <= 0.06) {
				enemy.actor.position.x = enemy.targetWorld.x;
				enemy.actor.position.z = enemy.targetWorld.z;
				enemy.velocity.set(0, 0, 0);
				levelState.col = waypoint.col;
				levelState.row = waypoint.row;
				levelState.pathIndex++;
			} else {
				enemy.moveDirection.divideScalar(distance);
				enemy.velocity.lerp(enemy.moveDirection.multiplyScalar(speed), Math.min(1, ENEMY_ACCEL * delta));
				const stepX = enemy.velocity.x * delta;
				const stepZ = enemy.velocity.z * delta;
				enemy.actor.position.x += stepX;
				enemy.actor.position.z += stepZ;
			}
		} else {
			enemy.velocity.multiplyScalar(Math.max(0, 1 - ENEMY_ACCEL * delta));
		}

		if (enemy.velocity.lengthSq() > 0.0004) {
			enemy.lookTarget.set(
				enemy.actor.position.x + enemy.velocity.x,
				enemy.actor.position.y,
				enemy.actor.position.z + enemy.velocity.z
			);
			enemy.lookMatrix.lookAt(enemy.actor.position, enemy.lookTarget, Y_AXIS);
			enemy.targetQuaternion.setFromRotationMatrix(enemy.lookMatrix);
			enemy.actor.quaternion.slerp(enemy.targetQuaternion, Math.min(1, ENEMY_ROTATE_SPEED * delta));
		}
	}

	function updateFoxEnemy(delta, elapsedTime) {
		if (!foxEnemy.actor) return;
		if (foxEnemy.mixer) {
			foxEnemy.mixer.update(delta);
		} else if (foxEnemy.actor.visible) {
			foxEnemy.actor.position.y = foxEnemy.height + Math.sin(elapsedTime * 4.8) * 0.035;
		}

		if (foxEnemy.currentLevel !== currentLevel) {
			syncEnemyForCurrentLevel(foxEnemy, 'foxSpawn', true);
		}

		if (!controls?.isLocked || levelTransition || gameOver) return;
		if (foxEnemy.catchCooldown > 0) foxEnemy.catchCooldown = Math.max(0, foxEnemy.catchCooldown - delta);
		const levelState = foxEnemy.levelStates[currentLevel];
		if (!levelState) return;
		const grid = getCurrentGrid();
		const enemyCell = worldToCell(foxEnemy.actor.position.x, foxEnemy.actor.position.z);
		if (inBounds(enemyCell.col, enemyCell.row) && grid[enemyCell.row][enemyCell.col] === 0) {
			levelState.col = enemyCell.col;
			levelState.row = enemyCell.row;
		}

		const playerCell = worldToCell(camera.position.x, camera.position.z);
		if (!inBounds(playerCell.col, playerCell.row) || grid[playerCell.row][playerCell.col] !== 0) return;

		updateEnemyChase(foxEnemy, levelState, grid, playerCell, delta, FOX_SPEED);
		const dx = camera.position.x - foxEnemy.actor.position.x;
		const dz = camera.position.z - foxEnemy.actor.position.z;
		if (foxEnemy.catchCooldown > 0) return;
		if (dx * dx + dz * dz > FOX_CATCH_RADIUS * FOX_CATCH_RADIUS) return;

		foxEnemy.catchCooldown = FOX_CATCH_COOLDOWN;
		registerPlayerHit('fox-touch');
	}

	function updateFaceEnemy(delta, elapsedTime) {
		if (!faceEnemy.actor) return;
		if (faceEnemy.actor.visible) {
			faceEnemy.actor.position.y = faceEnemy.height + Math.sin(elapsedTime * 3.2) * 0.075;
			if (faceEnemy.visual) faceEnemy.visual.rotation.z = Math.sin(elapsedTime * 1.7) * 0.05;
		}

		if (faceEnemy.currentLevel !== currentLevel) {
			syncEnemyForCurrentLevel(faceEnemy, 'faceSpawn', true);
			faceEnemy.shootTimer = FACE_SHOOT_INTERVAL * (0.65 + Math.random() * 0.5);
		}

		if (!controls?.isLocked || levelTransition || gameOver) return;
		const levelState = faceEnemy.levelStates[currentLevel];
		if (!levelState) return;
		const grid = getCurrentGrid();
		const enemyCell = worldToCell(faceEnemy.actor.position.x, faceEnemy.actor.position.z);
		if (inBounds(enemyCell.col, enemyCell.row) && grid[enemyCell.row][enemyCell.col] === 0) {
			levelState.col = enemyCell.col;
			levelState.row = enemyCell.row;
		}

		const playerCell = worldToCell(camera.position.x, camera.position.z);
		if (!inBounds(playerCell.col, playerCell.row) || grid[playerCell.row][playerCell.col] !== 0) return;

		updateEnemyChase(faceEnemy, levelState, grid, playerCell, delta, FACE_SPEED);
		faceEnemy.shootTimer -= delta;
		const playerDistance = Math.hypot(
			camera.position.x - faceEnemy.actor.position.x,
			camera.position.z - faceEnemy.actor.position.z
		);
		if (
			faceEnemy.shootTimer <= 0 &&
			playerDistance <= FACE_SHOOT_RANGE &&
			levelState.path.length > 0 &&
			levelState.path.length <= FACE_SHOOT_PATH_MAX
		) {
			spawnFaceProjectile();
			faceEnemy.shootTimer = FACE_SHOOT_INTERVAL * (0.75 + Math.random() * 0.4);
		}
	}

	function updateEnemies(delta, elapsedTime) {
		updateFoxEnemy(delta, elapsedTime);
		updateFaceEnemy(delta, elapsedTime);
	}

	function updateUi() {
		const { col, row } = worldToCell(camera.position.x, camera.position.z);
		const atExitLevel = currentLevel === EXIT_LEVEL;
		const exitDistance = atExitLevel
			? Math.hypot(camera.position.x - exitPosition.x, camera.position.z - exitPosition.z)
			: Infinity;

		debugEl.textContent = `Level: ${currentLevel + 1}/${LEVEL_COUNT} | Position: (${camera.position.x.toFixed(2)}, ${camera.position.z.toFixed(2)}) Cell: (${col}, ${row})`;
		healthEl.textContent = `Hits: ${playerHits}/${PLAYER_MAX_HITS}`;

		if (levelTransition) {
			const directionLabel = levelTransition.direction === 'down' ? 'Dropping' : 'Rising';
			statusEl.textContent = `${directionLabel} to level ${levelTransition.targetLevel + 1}...`;
			return;
		}

		if (gameOver) {
			statusEl.textContent = 'Game over. Press ENTER MAZE to restart.';
			return;
		}

		if (exitDistance < FINISH_DISTANCE) {
			statusEl.textContent = 'Exit reached. Press ESC to unlock and restart.';
			return;
		}

		if (currentLevel === 0) {
			statusEl.textContent = 'Top level: find red spheres to drop. Press SPACE at dead ends for hidden doors.';
			return;
		}

		if (currentLevel === EXIT_LEVEL) {
			statusEl.textContent = 'Final level: avoid the fox and face, then find the green exit beacon.';
			return;
		}

		statusEl.textContent = 'Use red spheres to go down, green to go up, and avoid the fox and face.';
	}

	function setMusicPlaying(shouldPlay) {
		if (!music) return;
		if (shouldPlay) {
			const playPromise = music.play();
			if (playPromise?.catch) playPromise.catch(() => {});
			return;
		}
		if (!music.paused) music.pause();
	}

	function updateRegionPulses(elapsedTime) {
		for (let i = 0; i < regionPulseMaterials.length; i++) {
			const material = regionPulseMaterials[i];
			const base = material.userData.baseEmissive ?? 0;
			const pulseAmp = material.userData.pulseAmp ?? 0;
			material.emissiveIntensity = base + Math.sin(elapsedTime * 1.7 + i * 0.85) * pulseAmp;
		}
	}

	function updateSky(elapsedTime, delta) {
		if (skyMaterial) skyMaterial.uniforms.time.value = elapsedTime;
		if (skyLayer) skyLayer.rotation.y += delta * 0.02;
		if (planetMesh) {
			planetMesh.position.x = -56 + Math.sin(elapsedTime * 0.07) * 8.5;
			planetMesh.position.y = 62 + Math.sin(elapsedTime * 0.12) * 1.8;
			planetMesh.rotation.y += delta * 0.09;
		}
		for (let i = 0; i < starLayers.length; i++) {
			const starLayerMesh = starLayers[i];
			starLayerMesh.rotation.y += delta * (0.012 + i * 0.006);
			starLayerMesh.rotation.x = Math.sin(elapsedTime * (0.05 + i * 0.02)) * 0.05;
		}
	}

	function updateTransitionSpheres(elapsedTime) {
		for (const sphere of transitionSphereMeshes) {
			sphere.orb.position.y = sphere.baseY + Math.sin(elapsedTime * 2.2 + sphere.phase) * 0.14;
			sphere.orb.rotation.y += 0.02;
			sphere.aura.rotation.z += 0.012;
			sphere.aura.material.opacity = 0.22 + Math.sin(elapsedTime * 3 + sphere.phase) * 0.08;
		}
	}

	function animate() {
		requestAnimationFrame(animate);
		const delta = clock.getDelta();
		const elapsedTime = clock.elapsedTime;
		if (playerHitCooldown > 0) playerHitCooldown = Math.max(0, playerHitCooldown - delta);

		if (controls.isLocked && !gameOver) {
			if (!levelTransition) {
				updateMovement(delta);
				maybeDropThroughDropSphere();
				maybeRiseThroughSphere();
			}
			updateLevelTransition(delta);
		}

		updateEnemies(delta, elapsedTime);
		if (controls.isLocked && !levelTransition && !gameOver) {
			updateProjectiles(delta);
		}
		updateSky(elapsedTime, delta);
		updateRegionPulses(elapsedTime);
		updateTransitionSpheres(elapsedTime);
		updateUi();
		composer.render(delta);
	}

	function init() {
		const container = document.getElementById('canvas-container');
		startButtonEl = document.getElementById('start-btn');
		debugEl = document.getElementById('debug');
		statusEl = document.getElementById('status');
		healthEl = document.getElementById('health');
		instructionsEl = document.getElementById('instructions');

		scene = new THREE.Scene();
		scene.background = new THREE.Color(0x132144);
		scene.fog = new THREE.Fog(0x132144, 76, 240);

		camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 300);
		renderer = new THREE.WebGLRenderer({ antialias: true });
		renderer.toneMapping = THREE.ACESFilmicToneMapping;
		renderer.toneMappingExposure = 1.24;
		renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
		renderer.setSize(window.innerWidth, window.innerHeight);
		container.appendChild(renderer.domElement);
		textureLoader = new THREE.TextureLoader();
		gltfLoader = new GLTFLoader();

		composer = new EffectComposer(renderer);
		composer.addPass(new RenderPass(scene, camera));
		bloomPass = new UnrealBloomPass(new THREE.Vector2(window.innerWidth, window.innerHeight), 0.46, 0.56, 0.88);
		filmPass = new FilmPass(0.16, 0.05, 648, false);
		composer.addPass(bloomPass);
		composer.addPass(filmPass);

		music = new Audio(track1Url);
		music.loop = true;
		music.volume = 0.35;
		music.preload = 'auto';

		controls = new PointerLockControls(camera, document.body);
		startButtonEl.addEventListener('click', () => {
			if (gameOver) {
				resetRun();
			}
			if (!musicReady) {
				music.load();
				musicReady = true;
			}
			controls.lock();
		});
		controls.addEventListener('lock', () => {
			instructionsEl.style.display = 'none';
			setMusicPlaying(true);
		});
		controls.addEventListener('unlock', () => {
			instructionsEl.style.display = 'block';
			setMusicPlaying(false);
		});

		const ambient = new THREE.AmbientLight(0x3d5f95, 0.8);
		scene.add(ambient);

		const hemi = new THREE.HemisphereLight(0x84a7e6, 0x24344f, 1.22);
		scene.add(hemi);

		const dir = new THREE.DirectionalLight(0xe3eeff, 1.44);
		dir.position.set(25, 42, 16);
		scene.add(dir);

		const fill = new THREE.DirectionalLight(0x9ab5ee, 0.72);
		fill.position.set(-28, 24, -30);
		scene.add(fill);

		addSkyBackdrop();
		initEnemies();
		loadFoxModel();
		resetRun();

		document.addEventListener('keydown', onKeyDown);
		document.addEventListener('keyup', onKeyUp);

		clock = new THREE.Clock();
		animate();
	}

	window.addEventListener('resize', () => {
		camera.aspect = window.innerWidth / window.innerHeight;
		camera.updateProjectionMatrix();
		renderer.setSize(window.innerWidth, window.innerHeight);
		if (composer) composer.setSize(window.innerWidth, window.innerHeight);
		if (bloomPass) bloomPass.setSize(window.innerWidth, window.innerHeight);
	});

	init();
</script>
